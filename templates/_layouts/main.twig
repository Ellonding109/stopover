<style>
/* Payment Cards Animation Styles */
.footer-two_cards {
    overflow: hidden;
    width: 280px;
    height: 50px;
    position: relative;
}

.payment-slider {
    width: 100%;
    height: 100%;
    position: relative;
}

.payment-track {
    display: flex;
    align-items: center;
    gap: 20px;
    position: absolute;
    animation: slideWithPauses 18s ease-in-out infinite;
    will-change: transform;
}

.payment-icon {
    flex-shrink: 0;
    transition: transform 0.3s ease, opacity 0.3s ease;
    opacity: 0.7;
    cursor: pointer;
}

.payment-icon img {
    height: 35px;
    width: auto;
    object-fit: contain;
    filter: grayscale(30%);
    transition: filter 0.3s ease, transform 0.3s ease;
}

.payment-icon:hover {
    opacity: 1;
    transform: scale(1.1);
}

.payment-icon:hover img {
    filter: grayscale(0%);
}

/* Keyframe animation with 3 stops/pauses */
@keyframes slideWithPauses {
    0% {
        transform: translateX(0);
    }
    20% {
        transform: translateX(-100px); /* Stop 1 */
    }
    28% {
        transform: translateX(-100px); /* Pause at Stop 1 */
    }
    40% {
        transform: translateX(-200px); /* Stop 2 */
    }
    48% {
        transform: translateX(-200px); /* Pause at Stop 2 */
    }
    60% {
        transform: translateX(-300px); /* Stop 3 */
    }
    68% {
        transform: translateX(-300px); /* Pause at Stop 3 */
    }
    85% {
        transform: translateX(0); /* Reset position */
    }
    100% {
        transform: translateX(0); /* Pause at start */
    }
}

/* Pause animation on hover */
.payment-slider:hover .payment-track {
    animation-play-state: paused;
}

.payment-slider:hover .payment-icon {
    opacity: 1;
}

.payment-slider:hover .payment-icon img {
    filter: grayscale(0%);
}

/* Responsive adjustments */
@media (max-width: 768px) {
    .footer-two_cards {
        width: 300px;
        height: 40px;
    }
    
    .payment-icon img {
        height: 28px;
    }
    
    .payment-track {
        gap: 15px;
    }
    
    @keyframes slideWithPauses {
        0% {
            transform: translateX(0);
        }
        20% {
            transform: translateX(-70px); /* Stop 1 */
        }
        28% {
            transform: translateX(-70px); /* Pause at Stop 1 */
        }
        40% {
            transform: translateX(-140px); /* Stop 2 */
        }
        48% {
            transform: translateX(-140px); /* Pause at Stop 2 */
        }
        60% {
            transform: translateX(-210px); /* Stop 3 */
        }
        68% {
            transform: translateX(-210px); /* Pause at Stop 3 */
        }
        85% {
            transform: translateX(0); /* Reset position */
        }
        100% {
            transform: translateX(0); /* Pause at start */
        }
    }
}
</style>

<script>
(function() {
    const form = document.getElementById('newsletter-form');
    if (!form) return;

    const emailInput = document.getElementById('newsletter-email');
    const statusEl = document.getElementById('newsletter-status');

    form.addEventListener('submit', async function(e) {
        e.preventDefault();

        const btn = form.querySelector('button[type="submit"]');
        const email = emailInput.value.trim();

        if (!email) return;

        btn.disabled = true;
        btn.textContent = 'Subscribing...';
        statusEl.style.display = 'none';

        try {
            const formData = new FormData();
            formData.append('email', email);

            const response = await fetch('/actions/newsletter/subscribe', {
                method: 'POST',
                body: formData
            });

            const result = await response.json();

            statusEl.style.display = 'block';

            if (result.success) {
                statusEl.innerHTML = '<div style="background:rgba(45,125,79,0.1);color:#2D7D4F;padding:14px 18px;border-radius:8px;margin-top:10px;font-size:0.9rem;line-height:1.5;">✓ ' + result.message + '</div>';
                emailInput.value = '';
            } else {
                const errors = result.errors || {};
                const msg = Object.values(errors).join('<br>');
                statusEl.innerHTML = '<div style="background:rgba(199,67,61,0.1);color:#C7433D;padding:14px 18px;border-radius:8px;margin-top:10px;font-size:0.9rem;line-height:1.5;">' + (msg || 'Subscription failed.') + '</div>';
            }
        } catch (error) {
            statusEl.style.display = 'block';
            statusEl.innerHTML = '<div style="background:rgba(199,67,61,0.1);color:#C7433D;padding:14px 18px;border-radius:8px;margin-top:10px;font-size:0.9rem;">Network error. Please try again.</div>';
        }

        btn.disabled = false;
        btn.textContent = 'Subscribe now';
    });
})();
</script>

