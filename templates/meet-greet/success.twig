{# templates/meet-greet/success.twig #}
{% extends "_layouts/base" %}

{% block body %}
<div class="page-wrapper">
    {% include "_includes/header" %}
    
    <!-- Success Banner -->
    <section class="success-banner" style="background: linear-gradient(135deg, var(--primary) 0%, #1a5276 100%);">
        <div class="auto-container">
            <div class="success-content text-center">
                <div class="success-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                </div>
                <h1>Booking Confirmed!</h1>
                <p class="lead">Thank you for booking our Meet & Greet service. Your reservation has been successfully processed.</p>
            </div>
        </div>
    </section>
    
    <!-- Booking Details Section -->
    <section class="booking-details-section py-5">
        <div class="auto-container">
            <div class="row justify-content-center">
                <div class="col-lg-8 col-md-12">
                    
                    <!-- Reference Card -->
                    <div class="reference-card mb-4">
                        <div class="reference-header">
                            <h3>Booking Reference</h3>
                            <span class="badge badge-success">Confirmed</span>
                        </div>
                        <div class="reference-number" id="bookingReference">
                            {{ craft.app.request.getParam('ref') ?: 'MNG-XXXXXX-XXXX' }}
                        </div>
                        <p class="reference-note">Save this number for future reference. A confirmation email has been sent to your registered email address.</p>
                        
                        <div class="reference-actions">
                            <button class="btn-outline" onclick="copyReference()">
                                <i class="fa fa-copy"></i> Copy Reference
                            </button>
                            <button class="btn-outline" onclick="window.print()">
                                <i class="fa fa-print"></i> Print Confirmation
                            </button>
                        </div>
                    </div>
                    
                    <!-- Booking Summary -->
                    <div class="booking-summary mb-4">
                        <h3 class="section-title">Booking Summary</h3>
                        
                        <div class="summary-grid">
                            <div class="summary-item">
                                <label>Service Type</label>
                                <span id="serviceType">{{ entry.serviceType == 'arrival' ? 'Arrival Meet & Greet' : 'Departure Meet & Greet' }}</span>
                            </div>
                            <div class="summary-item">
                                <label>Passenger Name</label>
                                <span id="passengerName">{{ entry.firstName ?? 'John' }} {{ entry.lastName ?? 'Doe' }}</span>
                            </div>
                            <div class="summary-item">
                                <label>Welcome Board Name</label>
                                <span id="pagerName">{{ entry.pagerName ?? entry.firstName ?? 'John Doe' }}</span>
                            </div>
                            <div class="summary-item">
                                <label>Flight Number</label>
                                <span id="flightNumber">{{ entry.flightNumber ?? 'KQ100' }}</span>
                            </div>
                            <div class="summary-item">
                                <label>Flight Date & Time</label>
                                <span id="flightDateTime">{{ entry.flightDate ?? 'MM/DD/YYYY' }} at {{ entry.flightTime ?? '14:30' }}</span>
                            </div>
                            <div class="summary-item">
                                <label>Passengers</label>
                                <span id="passengerCount">
                                    {{ entry.adults ?? 1 }} Adult{{ (entry.adults ?? 1) > 1 ? 's' : '' }}, 
                                    {{ entry.children ?? 0 }} Child{{ (entry.children ?? 0) != 1 ? 'ren' : '' }}
                                </span>
                            </div>
                        </div>
                    </div>
                    
                    <!-- What's Next -->
                    <div class="next-steps mb-4">
                        <h3 class="section-title">What Happens Next?</h3>
                        
                        <div class="steps-timeline">
                            <div class="step-item">
                                <div class="step-number">1</div>
                                <div class="step-content">
                                    <h4>Confirmation Email</h4>
                                    <p>You'll receive a detailed confirmation email with your booking reference and service details within 5 minutes.</p>
                                </div>
                            </div>
                            <div class="step-item">
                                <div class="step-number">2</div>
                                <div class="step-content">
                                    <h4>Pre-Flight Contact</h4>
                                    <p>Our team will contact you via WhatsApp or email 24 hours before your flight to confirm details and share meeting point instructions.</p>
                                </div>
                            </div>
                            <div class="step-item">
                                <div class="step-number">3</div>
                                <div class="step-content">
                                    <h4>Airport Meet & Greet</h4>
                                    <p>Look for our representative holding a welcome board with your name at the designated meeting point. They'll assist with immigration, baggage, and transfers.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Contact Support -->
                    <div class="support-card">
                        <h4>Need Help?</h4>
                        <p>Our support team is available 24/7 to assist you with any questions about your booking.</p>
                        
                        <div class="contact-options">
                            <a href="tel:+254116818181" class="contact-btn">
                                <i class="fa fa-phone"></i>
                                <span>+254 116 81 81 81</span>
                            </a>
                            <a href="https://wa.me/254116818181" class="contact-btn whatsapp" target="_blank">
                                <i class="fa-brands fa-whatsapp"></i>
                                <span>WhatsApp</span>
                            </a>
                            <a href="mailto:info@kenyastopover.com" class="contact-btn">
                                <i class="fa fa-envelope"></i>
                                <span>info@kenyastopover.com</span>
                            </a>
                        </div>
                    </div>
                    
                    <!-- Action Buttons -->
                    <div class="action-buttons text-center mt-5">
                        <a href="/" class="btn-primary btn-lg">
                            Return to Home
                        </a>
                        <a href="/meet-greet" class="btn-secondary btn-lg">
                            Book Another Service
                        </a>
                    </div>
                    
                </div>
            </div>
        </div>
    </section>
    
    <!-- Trust Badges -->
    <section class="trust-badges py-4" style="background: var(--bg-light);">
        <div class="auto-container">
            <div class="badges-grid text-center">
                <div class="badge-item">
                    <i class="fa fa-shield-alt"></i>
                    <span>Secure Payment</span>
                </div>
                <div class="badge-item">
                    <i class="fa fa-headset"></i>
                    <span>24/7 Support</span>
                </div>
                <div class="badge-item">
                    <i class="fa fa-check-circle"></i>
                    <span>Verified Service</span>
                </div>
                <div class="badge-item">
                    <i class="fa fa-sync-alt"></i>
                    <span>Free Cancellation*</span>
                </div>
            </div>
            <p class="badge-note text-center mt-3"><small>*Free cancellation up to 24 hours before service</small></p>
        </div>
    </section>
</div>

<style>
/* Success Banner */
.success-banner {
    padding: 60px 0;
    color: white;
}

.success-content {
    max-width: 700px;
    margin: 0 auto;
}

.success-icon {
    width: 100px;
    height: 100px;
    background: rgba(255,255,255,0.2);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 25px;
    animation: scaleIn 0.5s ease-out;
}

.success-icon svg {
    width: 50px;
    height: 50px;
    stroke: white;
}

.success-banner h1 {
    font-size: 2.5rem;
    margin-bottom: 15px;
    font-weight: 700;
}

.success-banner .lead {
    font-size: 1.2rem;
    opacity: 0.95;
    margin: 0;
}

/* Reference Card */
.reference-card {
    background: white;
    border-radius: 16px;
    padding: 30px;
    box-shadow: 0 4px 20px rgba(10, 61, 98, 0.08);
    border-left: 4px solid var(--success);
}

.reference-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
    padding-bottom: 15px;
    border-bottom: 1px solid var(--border);
}

.reference-header h3 {
    margin: 0;
    color: var(--primary);
    font-size: 1.3rem;
}

.badge-success {
    background: var(--success);
    color: white;
    padding: 6px 16px;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
}

.reference-number {
    font-family: monospace;
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--primary);
    text-align: center;
    padding: 20px;
    background: var(--bg-light);
    border-radius: 10px;
    margin: 20px 0;
    letter-spacing: 2px;
}

.reference-note {
    color: var(--text-light);
    font-size: 0.95rem;
    text-align: center;
    margin-bottom: 25px;
}

.reference-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
}

/* Booking Summary */
.booking-summary {
    background: white;
    border-radius: 16px;
    padding: 30px;
    box-shadow: 0 4px 20px rgba(10, 61, 98, 0.08);
}

.section-title {
    color: var(--primary);
    font-size: 1.4rem;
    margin-bottom: 25px;
    padding-bottom: 12px;
    border-bottom: 2px solid var(--secondary);
}

.summary-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
}

.summary-item {
    padding: 15px;
    background: var(--bg-light);
    border-radius: 10px;
}

.summary-item label {
    display: block;
    font-size: 0.85rem;
    color: var(--text-light);
    margin-bottom: 6px;
    font-weight: 500;
}

.summary-item span {
    font-weight: 600;
    color: var(--text-dark);
    font-size: 1.05rem;
}

/* Steps Timeline */
.next-steps {
    background: white;
    border-radius: 16px;
    padding: 30px;
    box-shadow: 0 4px 20px rgba(10, 61, 98, 0.08);
}

.steps-timeline {
    position: relative;
    padding-left: 20px;
}

.steps-timeline::before {
    content: '';
    position: absolute;
    left: 38px;
    top: 10px;
    bottom: 10px;
    width: 2px;
    background: var(--border);
}

.step-item {
    display: flex;
    gap: 20px;
    margin-bottom: 25px;
    position: relative;
}

.step-item:last-child {
    margin-bottom: 0;
}

.step-number {
    width: 36px;
    height: 36px;
    background: var(--primary);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1rem;
    flex-shrink: 0;
    z-index: 1;
}

.step-content h4 {
    margin: 0 0 8px 0;
    color: var(--primary);
    font-size: 1.1rem;
}

.step-content p {
    margin: 0;
    color: var(--text-light);
    font-size: 0.95rem;
    line-height: 1.5;
}

/* Support Card */
.support-card {
    background: rgba(10, 61, 98, 0.05);
    border-radius: 16px;
    padding: 25px;
    border: 2px solid var(--border);
}

.support-card h4 {
    color: var(--primary);
    margin-bottom: 10px;
}

.support-card > p {
    color: var(--text-light);
    margin-bottom: 20px;
    font-size: 0.95rem;
}

.contact-options {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 12px;
}

.contact-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 12px 20px;
    background: white;
    border: 2px solid var(--border);
    border-radius: 10px;
    text-decoration: none;
    color: var(--text-dark);
    font-weight: 500;
    transition: all 0.3s ease;
}

.contact-btn:hover {
    border-color: var(--primary);
    background: rgba(10, 61, 98, 0.05);
    color: var(--primary);
    transform: translateY(-2px);
}

.contact-btn.whatsapp {
    border-color: #25D366;
    color: #25D366;
}

.contact-btn.whatsapp:hover {
    background: #25D366;
    color: white;
}

.contact-btn i {
    font-size: 1.2rem;
}

/* Action Buttons */
.action-buttons {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
}

.btn-lg {
    padding: 16px 32px;
    font-size: 1.1rem;
}

.btn-secondary {
    background: transparent;
    color: var(--text-dark);
    border: 2px solid var(--border);
}

.btn-secondary:hover {
    border-color: var(--primary);
    color: var(--primary);
}

/* Trust Badges */
.badges-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 20px;
}

.badge-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    padding: 15px;
}

.badge-item i {
    font-size: 2rem;
    color: var(--primary);
}

.badge-item span {
    font-weight: 500;
    color: var(--text-dark);
    font-size: 0.95rem;
}

.badge-note {
    color: var(--text-light);
}

/* Animations */
@keyframes scaleIn {
    from {
        opacity: 0;
        transform: scale(0.5);
    }
    to {
        opacity: 1;
        transform: scale(1);
    }
}

/* Responsive */
@media (max-width: 768px) {
    .success-banner {
        padding: 40px 0;
    }
    
    .success-banner h1 {
        font-size: 2rem;
    }
    
    .success-banner .lead {
        font-size: 1.1rem;
    }
    
    .reference-card,
    .booking-summary,
    .next-steps,
    .support-card {
        padding: 25px;
    }
    
    .reference-number {
        font-size: 1.4rem;
    }
    
    .summary-grid {
        grid-template-columns: 1fr;
    }
    
    .steps-timeline::before {
        left: 28px;
    }
    
    .step-number {
        width: 32px;
        height: 32px;
        font-size: 0.9rem;
    }
    
    .action-buttons {
        flex-direction: column;
        align-items: center;
    }
    
    .btn-lg {
        width: 100%;
        max-width: 300px;
    }
}

/* Print Styles */
@media print {
    .page-wrapper > header,
    .reference-actions,
    .action-buttons,
    .trust-badges {
        display: none !important;
    }
    
    .success-banner {
        background: white !important;
        color: black !important;
        padding: 20px 0;
    }
    
    .success-icon {
        background: #eee !important;
    }
    
    .success-icon svg {
        stroke: black !important;
    }
    
    .reference-card,
    .booking-summary,
    .next-steps,
    .support-card {
        box-shadow: none !important;
        border: 1px solid #ddd !important;
        page-break-inside: avoid;
    }
    
    .reference-number {
        border: 2px dashed #333 !important;
    }
}
</style>

<script>
// Copy reference to clipboard
function copyReference() {
    const ref = document.getElementById('bookingReference').textContent.trim();
    navigator.clipboard.writeText(ref).then(() => {
        // Show temporary success message
        const btn = event.currentTarget;
        const originalText = btn.innerHTML;
        btn.innerHTML = '<i class="fa fa-check"></i> Copied!';
        btn.style.background = 'var(--success)';
        btn.style.color = 'white';
        btn.style.borderColor = 'var(--success)';
        
        setTimeout(() => {
            btn.innerHTML = originalText;
            btn.style.background = '';
            btn.style.color = '';
            btn.style.borderColor = '';
        }, 2000);
    }).catch(err => {
        console.error('Failed to copy:', err);
        alert('Could not copy reference. Please select and copy manually.');
    });
}

// Auto-focus on page load for accessibility
document.addEventListener('DOMContentLoaded', function() {
    // Add print hint for desktop users
    if (window.innerWidth > 768 && !window.matchMedia('print').matches) {
        const note = document.createElement('p');
        note.className = 'text-center text-muted mt-3';
        note.innerHTML = '<small><i class="fa fa-info-circle"></i> Tip: Press Ctrl+P (or Cmd+P on Mac) to print or save as PDF</small>';
        const actions = document.querySelector('.reference-actions');
        if (actions) {
            actions.parentNode.insertBefore(note, actions.nextSibling);
        }
    }
    
    // Animate elements on scroll
    const observerOptions = {
        threshold: 0.1,
        rootMargin: '0px 0px -50px 0px'
    };
    
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.style.opacity = '1';
                entry.target.style.transform = 'translateY(0)';
                observer.unobserve(entry.target);
            }
        });
    }, observerOptions);
    
    // Observe sections for scroll animation
    document.querySelectorAll('.reference-card, .booking-summary, .next-steps, .support-card').forEach(el => {
        el.style.opacity = '0';
        el.style.transform = 'translateY(20px)';
        el.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
        observer.observe(el);
    });
});
</script>

{% endblock %}